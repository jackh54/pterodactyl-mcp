# Pterodactyl Panel base URL (no trailing slash)
PTERODACTYL_PANEL_URL=https://panel.example.com

# Server bind
HOST=0.0.0.0
PORT=3000

# Master switch — set to false to disable all MCP endpoints
MCP_ENABLED=true

# Audit log file path (JSON lines). Omit to log to stdout.
# AUDIT_LOG_PATH=/var/log/pterodactyl-mcp/audit.jsonl

# Rate limit: max tool invocations per API key per minute
RATE_LIMIT_PER_MINUTE=60

# Panel API request timeout in milliseconds
PANEL_REQUEST_TIMEOUT_MS=30000

# Comma-separated allowed hosts for DNS rebinding protection (optional)
# ALLOWED_HOSTS=panel.example.com,localhost

# Command policy: strict | standard | admin
COMMAND_POLICY_MODE=standard

# Allowlist preset for strict mode: generic | minecraft | rust
COMMAND_POLICY_PRESET=generic

# Console WebSocket settings
CONSOLE_MAX_LINES=100
CONSOLE_TIMEOUT_MS=8000
CONSOLE_SESSION_IDLE_MS=300000
CONSOLE_MAX_SESSIONS=32

# File read limits
FILE_MAX_READ_BYTES=262144

# Power action confirmation (stop/restart/kill require token unless auto-confirm)
POWER_CONFIRMATION_TTL_MS=300000
POWER_AUTO_CONFIRM=false

# Optional comma-separated IP allowlist for MCP endpoint (supports trailing wildcard, e.g. 203.0.113.*)
# ALLOWED_IPS=127.0.0.1,203.0.113.*

# Optional per-server command policy overrides (JSON file)
# POLICY_OVERRIDES_PATH=./policies/overrides.json

# Auto-detect game type from docker image/startup for command policy preset
POLICY_AUTO_DETECT_EGG=false

# Phase 4 — opt-in mutating tools
ENABLE_FILE_WRITE=false
ENABLE_BACKUPS=false
FILE_MAX_WRITE_BYTES=65536
BACKUP_RATE_LIMIT_MS=3600000

# Prometheus metrics at /metrics
METRICS_ENABLED=true

# OAuth / token mapping
# MCP_ADMIN_SECRET=change-me-for-dcr
# MCP_TOKEN_MAP_PATH=./policies/token-map.json
